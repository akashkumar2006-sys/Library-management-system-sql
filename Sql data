Basic Queries
View All Students
SELECT * FROM Students;

View All Books
SELECT * FROM Books;

Books Issued by Students
SELECT Students.student_name, Books.book_name
FROM IssuedBooks
JOIN Students
ON IssuedBooks.student_id = Students.student_id
JOIN Books
ON IssuedBooks.book_id = Books.book_id;

Count Total Books
SELECT COUNT(*) AS Total_Books
FROM Books;

Find Students from CSE Department
SELECT * FROM Students
WHERE department = 'CSE';

Find Books Not Returned
SELECT * FROM IssuedBooks
WHERE return_date IS NULL;

Count Books Issued by Each Student
SELECT student_id, COUNT(book_id) AS total_books
FROM IssuedBooks
GROUP BY student_id;

Show Available Books Greater Than 4
SELECT * FROM Books
WHERE available_copies > 4;

Update Available Copies
UPDATE Books
SET available_copies = 4
WHERE book_id = 101;

Delete a Student Record
DELETE FROM Students
WHERE student_id = 4;


